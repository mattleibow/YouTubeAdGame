@using SkiaSharp
@using SkiaSharp.Views.Blazor
@using YouTubeAdGame.Engine.Core
@using YouTubeAdGame.Engine.Engine
@using YouTubeAdGame.Engine.Rendering
@using YouTubeAdGame.Web.Input
@using YouTubeAdGame.Web.Services

@implements IAsyncDisposable

<div class="page-layout">

    <div class="game-container"
         tabindex="0"
         @onkeydown="OnKeyDown"
         @onkeyup="OnKeyUp"
         @onkeydown:preventDefault="true"
         @ontouchstart="OnTouchStart"
         @ontouchmove="OnTouchMove"
         @ontouchend="OnTouchEnd"
         @ontouchstart:preventDefault="true"
         @ontouchmove:preventDefault="true"
         @onmousedown="OnMouseDown"
         @onmousemove="OnMouseMove"
         @onmouseup="OnMouseUp"
         @ref="_containerRef">

        <SKCanvasView @ref="_canvasView"
                      class="game-canvas"
                      OnPaintSurface="OnPaintSurface"
                      EnableRenderLoop="false"
                      IgnorePixelScaling="false" />
    </div>

    <div class="inspector-panel">
        <div class="inspector-title">Inspector</div>

        <div class="inspector-section">
            <div class="inspector-label">Phase</div>
            <div class="inspector-value">@_state.Phase</div>
        </div>
        <div class="inspector-section">
            <div class="inspector-label">Wave</div>
            <div class="inspector-value">@_state.Wave</div>
        </div>
        <div class="inspector-section">
            <div class="inspector-label">Score</div>
            <div class="inspector-value">@_state.Score</div>
        </div>
        <div class="inspector-section">
            <div class="inspector-label">Distance</div>
            <div class="inspector-value">@((int)_state.Distance)</div>
        </div>

        <div class="inspector-divider"></div>

        <div class="inspector-section">
            <div class="inspector-label">Soldiers</div>
            <div class="inspector-value">@_state.Crowd.Count</div>
        </div>
        <div class="inspector-section">
            <div class="inspector-label">Zombies</div>
            <div class="inspector-value">@_state.Enemies.Count</div>
        </div>
        <div class="inspector-section">
            <div class="inspector-label">Bullets</div>
            <div class="inspector-value">@_state.PlayerBullets.Count</div>
        </div>
        <div class="inspector-section">
            <div class="inspector-label">Particles</div>
            <div class="inspector-value">@_state.Particles.Count</div>
        </div>

        <div class="inspector-divider"></div>

        <div class="inspector-label">Max zombies: @_state.MaxEnemiesOnScreen</div>
        <input type="range"
               class="inspector-slider"
               min="1" max="1000"
               value="@_state.MaxEnemiesOnScreen"
               @oninput="OnMaxEnemiesChanged" />

        <div class="inspector-label">Spawn delay: @((int)(_state.SpawnInterval * 1000)) ms</div>
        <input type="range"
               class="inspector-slider"
               min="50" max="2000" step="10"
               value="@((int)(_state.SpawnInterval * 1000))"
               @oninput="OnSpawnIntervalChanged" />

        <div class="inspector-label">Max shooters/salvo: @_state.MaxConcurrentShooters</div>
        <input type="range"
               class="inspector-slider"
               min="1" max="50"
               value="@_state.MaxConcurrentShooters"
               @oninput="OnMaxShootersChanged" />

        <div class="inspector-hint">Sliders change settings in real-time.</div>

        <div class="inspector-divider"></div>

        <div class="inspector-label">Game Mode</div>
        <div class="mode-selector">
            <button class="mode-arrow" @onclick="CycleModeBack">&lt;</button>
            <span class="mode-name">@GetModeName()</span>
            <button class="mode-arrow" @onclick="CycleModeForward">&gt;</button>
        </div>

        <a class="editor-link" href="editor">Edit Custom Map</a>

    </div>

</div>

@code {
    // ── Dependencies ──────────────────────────────────────────────────────
    private readonly GameState          _state    = new();
    private readonly BlazorInputProvider _input   = new();
    private GameEngine?                 _engine;
    private SkiaGameRenderer?           _renderer;
    private SKCanvasView?               _canvasView;
    private ElementReference            _containerRef;

    // ── Game loop ─────────────────────────────────────────────────────────
    private PeriodicTimer?   _timer;
    private CancellationTokenSource _cts = new();
    private int _frameCount;

    [Inject] private IJSRuntime      JS         { get; set; } = default!;
    [Inject] private CustomMapService MapStorage { get; set; } = default!;
    [Inject] private NavigationManager Nav       { get; set; } = default!;

    // All built-in modes plus Custom
    private static readonly GameMode[] AllModes =
        [..MapRegistry.GetAll().Select(x => x.Mode), GameMode.Custom];

    protected override void OnInitialized()
    {
        _renderer = new SkiaGameRenderer();
        _engine   = new GameEngine(_input);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Check for ?playCustom=1 query string (navigated from editor "Play Now")
        if (Nav.Uri.Contains("playCustom=1", StringComparison.OrdinalIgnoreCase))
        {
            await SwitchToCustomModeAsync();
            _engine?.StartGame(_state);
        }

        // Start 60 Hz game loop
        _timer = new PeriodicTimer(TimeSpan.FromMilliseconds(1000.0 / 60.0));
        _ = RunGameLoopAsync(_cts.Token);

        // Give the container focus so keyboard events work
        await JS.InvokeVoidAsync("focusElement", _containerRef);
    }

    private async Task RunGameLoopAsync(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested && _timer is not null)
        {
            try
            {
                await _timer.WaitForNextTickAsync(ct);
            }
            catch (OperationCanceledException)
            {
                break;
            }

            _engine?.Update(_state, (float)GameConstants.FixedDeltaTime);
            _canvasView?.Invalidate();

            // Refresh the inspector panel ~6× per second (every 10 frames)
            _frameCount++;
            if (_frameCount % 10 == 0)
                await InvokeAsync(StateHasChanged);
        }
    }

    // ── Rendering ─────────────────────────────────────────────────────────

    private void OnPaintSurface(SKPaintSurfaceEventArgs e)
    {
        var canvas = e.Surface.Canvas;
        canvas.Clear(SKColors.Black);

        _state.ViewportWidth  = e.Info.Width;
        _state.ViewportHeight = e.Info.Height;

        _renderer?.Render(canvas, _state);
    }

    // ── Input ─────────────────────────────────────────────────────────────

    private void HandleTap(float x, float y)
    {
        _input.OnPointerDown(x, y, _state.ViewportWidth);

        if (_state.Phase is GamePhase.Menu or GamePhase.GameOver or GamePhase.Victory)
        {
            _engine?.StartGame(_state);
        }
    }

    private void OnMouseDown(MouseEventArgs e) =>
        HandleTap((float)e.OffsetX, (float)e.OffsetY);

    private void OnMouseMove(MouseEventArgs e)
    {
        if (e.Buttons == 1)  // left button held
            _input.OnPointerMove((float)e.OffsetX, (float)e.OffsetY, _state.ViewportWidth);
    }

    private void OnMouseUp(MouseEventArgs e) => _input.OnPointerUp();

    private void OnTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length == 0) return;
        var t = e.Touches[0];
        HandleTap((float)t.ClientX, (float)t.ClientY);
    }

    private void OnTouchMove(TouchEventArgs e)
    {
        if (e.Touches.Length == 0) return;
        var t = e.Touches[0];
        _input.OnPointerMove((float)t.ClientX, (float)t.ClientY, _state.ViewportWidth);
    }

    private void OnTouchEnd(TouchEventArgs e) => _input.OnPointerUp();

    private void OnKeyDown(KeyboardEventArgs e)
    {
        _input.OnKeyDown(e.Key);
        if (e.Key is " " or "Enter")
        {
            if (_state.Phase is GamePhase.Menu or GamePhase.GameOver or GamePhase.Victory)
                _engine?.StartGame(_state);
        }
        else if (_state.Phase == GamePhase.Menu)
        {
            if (e.Key is "ArrowLeft")  _ = CycleModeBackAsync();
            if (e.Key is "ArrowRight") _ = CycleModeForwardAsync();
        }
    }

    private void OnKeyUp(KeyboardEventArgs e) => _input.OnKeyUp(e.Key);

    // ── Mode cycling ──────────────────────────────────────────────────────

    private string GetModeName()
    {
        if (_state.Mode == GameMode.Custom)
            return _state.ActiveMap is not null ? _state.ActiveMap.Name : "Custom";
        return MapRegistry.Get(_state.Mode).Name;
    }

    private void CycleModeBack()    => _ = CycleModeBackAsync();
    private void CycleModeForward() => _ = CycleModeForwardAsync();

    private async Task CycleModeBackAsync()
    {
        int idx = Array.IndexOf(AllModes, _state.Mode);
        _state.Mode = AllModes[(idx - 1 + AllModes.Length) % AllModes.Length];
        await OnModeChangedAsync();
    }

    private async Task CycleModeForwardAsync()
    {
        int idx = Array.IndexOf(AllModes, _state.Mode);
        _state.Mode = AllModes[(idx + 1) % AllModes.Length];
        await OnModeChangedAsync();
    }

    private async Task OnModeChangedAsync()
    {
        if (_state.Mode == GameMode.Custom)
            await SwitchToCustomModeAsync();
        else
            _state.ActiveMap = null;  // will be loaded fresh at StartGame
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>Load the stored active custom map into state.</summary>
    private async Task SwitchToCustomModeAsync()
    {
        _state.Mode = GameMode.Custom;
        var map = await MapStorage.LoadActiveMapAsync();
        if (map is not null)
            _state.ActiveMap = map;
    }

    // ── Inspector ─────────────────────────────────────────────────────────

    private void OnMaxEnemiesChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int value))
            _state.MaxEnemiesOnScreen = value;
    }

    private void OnSpawnIntervalChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int ms))
            _state.SpawnInterval = ms / 1000f;
    }

    private void OnMaxShootersChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int value))
            _state.MaxConcurrentShooters = System.Math.Max(1, value);
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
        _timer?.Dispose();
        _renderer?.Dispose();
    }
}
